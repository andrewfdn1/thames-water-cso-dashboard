# Copy this to /opt/thames-cso-dashboard/.env on the Pi and fill in real
# values. Never commit the filled-in version -- this file only exists as a
# template of which variables the systemd service needs.

TURSO_DATABASE_URL=libsql://thames-cso-water-quality-andrewfdn1.aws-eu-west-1.turso.io
TURSO_AUTH_TOKEN=
TURSO_DISCHARGE_DATABASE_URL=libsql://thames-cso-discharge-history-andrewfdn1.aws-eu-west-1.turso.io
TURSO_DISCHARGE_AUTH_TOKEN=

# Shared secrets for the two /internal/* endpoints. Required -- both
# endpoints refuse all requests if their key is unset, since this app is
# now reachable behind a stable public domain rather than an obscure
# Render subdomain. Generate each with: openssl rand -hex 24
DISCHARGE_SYNC_KEY=
LOGS_KEY=

# Where the systemd unit redirects this app's stdout/stderr -- must match
# StandardOutput/StandardError in thames-cso-dashboard.service.
APP_LOG_PATH=/opt/thames-cso-dashboard/logs/app.log
